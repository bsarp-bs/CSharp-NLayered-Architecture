@using EntityLayer.Concrete_Entities
@model List<Service>

@{
    ViewData["Title"] = "ServiceIndex";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Hizmet Listesi</h1>


<table class="table table-bordered">
    <tr>
        <th>#</th>
        <th>Başlık</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.ServiceID</td>
            <td>@item.Title</td>
        </tr>
    }

</table>

<a href="~/ServiceWithModelController1/AddService" class="btn btn-success">Yeni Hizmet</a>