@model EntityLayer.Concrete_Entities.Service

@{
    ViewData["Title"] = "EditService";
    Layout = "~/Views/Shared/GeneralLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">

            <h4 class="card-title">Hizmet Güncelle</h4>

            <form class="forms-sample" method="post">

                <input type="hidden" asp-for="ServiceID" />

                <div class="form-group">
                    <label asp-for="Title">Hizmet</label>
                    <input asp-for="Title" class="form-control" placeholder="Hizmet adı">
                </div>

                <div class="form-group">
                    <label asp-for="Desc">Açıklama</label>
                    <input asp-for="Desc" class="form-control" placeholder="Açıklama">
                </div>

                <div class="form-group">
                    <label asp-for="Img">Görsel</label>
                    <input asp-for="Img" class="form-control" placeholder="Görsel yolu">
                </div>

                <button type="submit" class="btn btn-success">Güncelle</button>

            </form>

        </div>
    </div>
</div>