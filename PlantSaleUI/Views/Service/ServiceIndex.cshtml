@using EntityLayer.Concrete_Entities
@model List<Service>

@{
    ViewData["Title"] = "ServiceIndex";
    Layout = "~/Views/Shared/GeneralLayout.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">

            <h4 class="card-title">Hizmet Listesi</h4>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Başlık</th>
                        <th>Açıklama</th>
                        <th>Görsel</th>
                        <th>Sil</th>
                        <th>Güncelle</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ServiceID</td>
                            <td>@item.Title</td>
                            <td>@item.Desc</td>
                            <td>@item.Img</td>

                            <td>
                                <a asp-controller="Service"
                                   asp-action="DeleteService"
                                   asp-route-id="@item.ServiceID"
                                   class="btn btn-danger btn-sm">
                                    Sil
                                </a>
                            </td>

                            <td>
                                <a asp-controller="Service"
                                   asp-action="EditService"
                                   asp-route-id="@item.ServiceID"
                                   class="btn btn-warning btn-sm">
                                    Güncelle
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <a asp-controller="Service"
               asp-action="AddService"
               class="btn btn-success">
                Yeni Hizmet
            </a>

        </div>
    </div>
</div>