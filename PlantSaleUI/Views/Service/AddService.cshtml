@model EntityLayer.Concrete_Entities.Service

@{
    ViewData["Title"] = "AddService";
    Layout = "~/Views/Shared/GeneralLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Yeni Hizmet Kaydı</h4>

            <form class="forms-sample" method="post">

                <div class="form-group">
                    <label asp-for="Title">Hizmet</label>
                    <input asp-for="Title" class="form-control" placeholder="Hizmet adı giriniz">
                </div>

                <div class="form-group">
                    <label asp-for="Desc">Açıklama</label>
                    <input asp-for="Desc" class="form-control" placeholder="Açıklama giriniz">
                </div>

                <div class="form-group">
                    <label asp-for="Img">Görsel</label>
                    <input asp-for="Img" class="form-control" placeholder="Görsel yolu">
                </div>

                <button type="submit" class="btn btn-outline-primary">Kaydet</button>

            </form>

        </div>
    </div>
</div>