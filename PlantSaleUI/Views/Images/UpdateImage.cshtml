@model EntityLayer.Concrete_Entities.Images
@{
    ViewData["Title"] = "UpdateImage";
    Layout = "~/Views/Shared/GeneralLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">

            <h4 class="card-title">Görsel Ekle</h4>

            <form class="forms-sample" method="post">

                <input type="hidden" asp-for="ImagesID" />

                <div class="form-group">
                    <label asp-for="Title">Görsel adı </label>
                    <input asp-for="Title" class="form-control" placeholder="Görsel adı">
                </div>

                <div class="form-group">
                    <label asp-for="Desc">Açıklama</label>
                    <input asp-for="Desc" class="form-control" placeholder="Açıklama">
                </div>

                <div class="form-group">
                    <label asp-for="ImgURL">URL</label>
                    <span asp-validation-for="ImgURL" class="text-danger"></span>
                    <input asp-for="ImgURL" class="form-control" placeholder="URL" />
                    <div />

                    <button type="submit" class="btn btn-success">Ekle</button>

            </form>

        </div>
    </div>
</div>