@model EntityLayer.Concrete_Entities.Communication

@{
    ViewData["Title"] = "AddCommunication";
    Layout = "~/Views/Shared/GeneralLayout.cshtml";
}


<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Yeni İstek Kaydı</h4>

            <form class="forms-sample" method="post">

                <div class="form-group">
                    <label asp-for="Name">Başlık</label>
                    <span asp-validation-for="Name" class="text-danger"></span>
                    <input asp-for="Name" class="form-control" placeholder="Başlık adı giriniz">
                </div>

                <div class="form-group">
                    <label asp-for="Mail">Mail</label>
                    <input asp-for="Mail" class="form-control" placeholder="Mail giriniz">
                </div>

                <div class="form-group">
                    <label asp-for="Comment">Yorum</label>
                    <textarea asp-for="Comment" class="form-control" rows="5" placeholder="Yorum giriniz"></textarea>
                </div>

                <div class="form-group">
                    <label asp-for="Date">Tarih</label>
                    <input asp-for="Date" class="form-control" placeholder="Tarih giriniz">
                </div>

                <button type="submit" class="btn btn-outline-primary">Kaydet</button>

            </form>

        </div>
    </div>
</div>