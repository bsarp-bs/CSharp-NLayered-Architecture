@using EntityLayer.Concrete_Entities
@model List<SocialMedia>


<div class="w3l_header_right">
	<div class="w3ls-social-icons text-left">
		@foreach(var item in Model)
		{ 
		<a class="@item.Title" href="@item.URL"><i class="@item.Icon"></i></a>
		}

		<a class="btn btn-success" href="~/Login/LogIN">Kayıt Ol</a>

		<a class="btn btn-success" href="~/Login/LoginIndex">Giriş Yap</a>
	</div>
</div>