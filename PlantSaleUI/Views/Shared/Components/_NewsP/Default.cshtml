@using EntityLayer.Concrete_Entities
@model List<Journal>

<!--blog -->
<div class="blog" id="blog">
	<div class="container">
		<h3 class="tittle">Duyurular</h3>


		<p class="heading-btm-w3ls">Son güncellemeler</p>

		@foreach(var item in Model)
		{

		<div class="blog-grid-w3-agileits">
			<div class=" col-md-7 blog-img3-agileits-w3layouts">
				<a href="#" data-toggle="modal" data-target="#myModal4"></a>
			</div>
			<div class=" col-md-5 blog-info-w3layouts">
				<h6><a href="#">@item.Title</a></h6>
				<div class="inner-info">
					<a href="#" class="blog-text-w3ls bar">Admin</a><span>06/8/2026</span>
					<p class="para-w3-agileits">@item.Desc</p>
				</div>

			</div>
			<div class="clearfix"></div>
		</div>

		}


	</div>
</div>
<!-- //blog -->