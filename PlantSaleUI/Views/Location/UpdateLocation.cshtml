@model EntityLayer.Concrete_Entities.Location
@{
    ViewData["Title"] = "UpdateLocation";
    Layout = "~/Views/Shared/GeneralLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Adres Kaydı</h4>

            <form class="forms-sample" method="post">

                <input type="hidden" asp-for="LocationID" />

                <div class="form-group">
                    <label asp-for="Desc1">Tanım1</label>
                    <input asp-for="Desc1" class="form-control" placeholder="Tanım giriniz">
                </div>

                <div class="form-group">
                    <label asp-for="Desc2">Tanım2</label>
                    <input asp-for="Desc2" class="form-control" placeholder="Tanım giriniz">
                </div>

                <div class="form-group">
                    <label asp-for="Desc3">Tanım3</label>
                    <input asp-for="Desc3" class="form-control" placeholder="Tanım giriniz">
                </div>

                <div class="form-group">
                    <label asp-for="Desc4">Tanım4</label>
                    <input asp-for="Desc4" class="form-control" placeholder="Tanım giriniz">
                </div>

                <button type="submit" class="btn btn-outline-primary">Kaydet</button>

            </form>

        </div>
    </div>
</div>


