@using EntityLayer.Concrete_Entities
@model List<Location>

@{
    ViewData["Title"] = "LocIndex";
    Layout = "~/Views/Shared/GeneralLayout.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">

            <h4 class="card-title">Adres Listesi</h4>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <td>#</td>
                        <td>Tanım1</td>
                        <td>Tanım2</td>
                        <td>Tanım3</td>
                        <td>Tanım4</td>
                        <td>Sil</td>
                        <td>Güncelle</td>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.LocationID</td>
                            <td>@item.Desc1</td>
                            <td>@item.Desc2</td>
                            <td>@item.Desc3</td>
                            <td>@item.Desc4</td>

                            <td>
                                <a asp-action="DeleteLocation"
                                   asp-controller="Location"
                                   asp-route-id="@item.LocationID"
                                   class="btn btn-outline-info">Sil</a>
                            </td>

                            <td>
                                <a asp-action="UpdateLocation"
                                   asp-controller="Location"
                                   asp-route-id="@item.LocationID"
                                   class="btn btn-outline-info">Güncelle</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <a asp-action="AddLocation"
               asp-controller="Location"
               class="btn btn-success form-group">Yeni Ekle</a>

        </div>
    </div>
</div>
