@model EntityLayer.Concrete_Entities.Journal

@{
    ViewData["Title"] = "AddJournal";
    Layout = "~/Views/Shared/GeneralLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Yeni Duyuru Kaydı</h4>

            <form class="forms-sample" method="post">

                <div class="form-group">
                    <label asp-for="Title">Duyuru</label>
                    <input asp-for="Title" class="form-control" placeholder="Duyuru adı giriniz">
                </div>

                <div class="form-group">
                    <label asp-for="Date">Tarih</label>
                    <input asp-for="Date" class="form-control" placeholder="Tarih giriniz">
                </div>

                <div class="form-group">
                    <label asp-for="Desc">Açıklama</label>
                    <input asp-for="Desc" class="form-control" placeholder="Açıklama giriniz">
                </div>

                <div class="form-group">
                    <label asp-for="Status">Durum</label>
                    <select asp-for="Status" class="form-control">
                        <option value="true">Aktif</option>
                        <option value="false">Pasif</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-outline-primary">Kaydet</button>

            </form>

        </div>
    </div>
</div>