@using EntityLayer.Concrete_Entities
@model List<Journal>

@{
    ViewData["Title"] = "JournalIndex";
    Layout = "~/Views/Shared/GeneralLayout.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">

            <h4 class="card-title">Duyuru Listesi</h4>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <td>#</td>
                        <td>Duyuru</td>
                        <td>Açıklama</td>
                        <td>Tarih</td>
                        <td>Durum</td>
                        <td>Sil</td>
                        <td>Güncelle</td>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.JournalID</td>
                            <td>@item.Title</td>
                            <td>@item.Desc</td>
                            <td>@item.Date</td>
                            <td>@(item.Status == true ? "Aktif" : "Pasif")</td>

                            <td>
                                <a asp-action="DeleteJournal"
                                   asp-controller="Journal"
                                   asp-route-id="@item.JournalID"
                                   class="btn btn-outline-info">Sil</a>
                            </td>

                            <td>
                                <a asp-action="UpdateJournal"
                                   asp-controller="Journal"
                                   asp-route-id="@item.JournalID"
                                   class="btn btn-outline-info">Güncelle</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <a asp-action="AddJournal"
               asp-controller="Journal"
               class="btn btn-success form-group">Yeni Ekle</a>

        </div>
    </div>
</div>